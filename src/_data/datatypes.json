[
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/Text",
        "name": "Text",
        "description": "Any string value. The base text type with no format constraints."
    },
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/String",
        "name": "String",
        "parent": "https://schema.host/Text",
        "description": "A string value. Inherits from Text with no additional format constraints."
    },
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/URL",
        "name": "URL",
        "parent": "https://schema.host/Text",
        "description": "A valid URL.",
        "matches": "^[A-Za-z][A-Za-z0-9+.-]*://(([A-Za-z0-9._~!$&'()*+,;=-]|%[0-9A-Fa-f]{2})+@)?(\\[([0-9A-Fa-f:.]+)\\]|([A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?\\.)*[A-Za-z]([A-Za-z0-9-]*[A-Za-z0-9])?|[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+)(:[0-9]+)?(/([A-Za-z0-9._~!$&'()*+,;:@=-]|%[0-9A-Fa-f]{2})*)*(\\?([A-Za-z0-9._~!$&'()*+,;:@/?=-]|%[0-9A-Fa-f]{2})*)?(#([A-Za-z0-9._~!$&'()*+,;:@/?=-]|%[0-9A-Fa-f]{2})*)?$"
    },
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/Number",
        "name": "Number",
        "description": "A numeric value, either integer or floating-point.",
        "matches": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$"
    },
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/Integer",
        "name": "Integer",
        "parent": "https://schema.host/Number",
        "description": "A 64-bit signed integer.",
        "matches": "^-?[0-9]+$"
    },
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/FloatingPoint",
        "name": "FloatingPoint",
        "parent": "https://schema.host/Number",
        "description": "An IEEE 754 floating-point number.",
        "matches": "^-?[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?$"
    },
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/DateTime",
        "name": "DateTime",
        "description": "An RFC 3339 date-time value.",
        "matches": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([.][0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    {
        "@type": "DataType",
        "@context": "https://schema.host/",
        "@id": "https://schema.host/Date",
        "name": "Date",
        "parent": "https://schema.host/DateTime",
        "description": "An ISO 8601 date (YYYY-MM-DD).",
        "matches": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
]
